{
  "manifest_version": 3,
  "name": "LiveLyric - Buscador de Letras em Tempo Real",
  "version": "1.0.1",
  "description": "Detecta músicas tocando no navegador e busca a letra automaticamente via Genius API.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "host_permissions": [
    "https://api.genius.com/*",
    "https://genius.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LiveLyric",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
